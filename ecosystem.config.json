{
  "apps": [
    {
      "name": "servimarket-api",
      "script": "artifacts/api-server/dist/index.mjs",
      "instances": 1,
      "exec_mode": "fork",
      "env": {
        "NODE_ENV": "production",
        "SESSION_SECRET": "<SESSION_SECRET>",
        "ALLOWED_ORIGINS": "<ALLOWED_ORIGINS>",
        "APP_URL": "<APP_URL>",
        "DATABASE_URL": "<DATABASE_URL>",
        "PORT": "<PORT>",
        "RESEND_API_KEY": "<RESEND_API_KEY>",
        "RESEND_FROM": "<RESEND_FROM>"
      },
      "env_production": {
        "NODE_ENV": "production"
      }
    }
  ]
}
